#!/usr/bin/env tclsh9

# 引入官方标准的测试大组件
# package require tcltest 2.5
package require tcltest
namespace import ::tcltest::*

# 跨层级把我们刚刚收工的 tutils 工具箱的绝对路径加载进来
set current_dir [file dirname [file normalize [info script]]]
lappend ::auto_path [file dirname $current_dir]
package require tutils 1.0

test ip-addr-1.1 {测试回环网卡解析：验证 local loopback 网卡必须能够被雷达精准捕获且状态为 UP} -setup {
    # 无需环境依赖，直接调用
} -body {
    set result [ip get_addresses]

    puts [log pdict $result]

    # 任何正常的 Linux 宇宙里，都 100% 存在 lo 网卡
    set has_lo [dict exists $result "lo"]
    set lo_state "unknown"
    if {$has_lo} {
        set lo_state [dict get $result lo state]
    }

    # 【核心生产对齐锁】：兼容真实 Linux 内核中虚拟回环网卡可能表现为 UNKNOWN 或 UP 的真实物理规律
    expr {$has_lo && ($lo_state eq "UP" || $lo_state eq "UNKNOWN")}
} -cleanup {
} -result 1

test ip-addr-1.2 {测试 MAC 地址解析：验证物理或虚拟网卡必须持有合法的 17 位物理 MAC 地址} -body {
    set result [ip get_addresses]
    set has_eth0 [dict exists $result "eth0"]
    set mac "none"
    if {$has_eth0} { set mac [dict get $result eth0 mac] }
    # 核心验证点：eth0 网卡存在，且其 MAC 地址必须符合标准 17 位十六进制格式
    regexp {^[0-9a-f]{2}(:[0-9a-f]{2}){5}$} $mac
} -result 1

test ip-addr-1.3 {测试 IPv6 链路本地地址捕获：验证系统回环或物理网卡中必须成功提取出 IPv6 地址容器} -body {
    set result [ip get_addresses]
    set has_lo [dict exists $result "lo"]
    set lo_ipv6 {}
    if {$has_lo} { set lo_ipv6 [dict get $result lo ipv6] }
    # 核心验证点：lo 网卡中必须包含合法的本地回环 IPv6 地址 "::1/128"
    expr {[llength $lo_ipv6] > 0 && [lindex $lo_ipv6 0] eq "::1/128"}
} -result 1

# ====================================================================
# 自动化测试大盘收尾：统计红绿灯通过率
# ====================================================================
cleanupTests

